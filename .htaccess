# 1. Empêcher le listage des répertoires (Sécurité)
Options -Indexes

# 2. Forcer le HTTPS (Sécurité et SEO)
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. Supprimer l'extension .html des URLs (Optionnel, pour faire plus pro)
# Exemple : www.bois-gestion.fr/contact au lieu de /contact.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# 4. Gestion des erreurs 404 (Rediriger vers l'accueil si page introuvable)
ErrorDocument 404 /index.html

# 5. Cache navigateur (Pour la rapidité demandée par Google PageSpeed)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
</IfModule>